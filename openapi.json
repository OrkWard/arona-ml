{
  "openapi": "3.1.0",
  "info": {
    "title": "FastAPI",
    "version": "0.1.0"
  },
  "paths": {
    "/get-image-hash": {
      "post": {
        "summary": "Process Image",
        "operationId": "process_image_get_image_hash_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageUrlRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageHashResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ImageHashResponse": {
        "properties": {
          "perceptual_hash": {
            "type": "string",
            "title": "Perceptual Hash"
          },
          "pdqhash": {
            "$ref": "#/components/schemas/PdqHashResult"
          }
        },
        "type": "object",
        "required": [
          "perceptual_hash",
          "pdqhash"
        ],
        "title": "ImageHashResponse"
      },
      "ImageUrlRequest": {
        "properties": {
          "url": {
            "type": "string",
            "maxLength": 2083,
            "minLength": 1,
            "format": "uri",
            "title": "Url"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "ImageUrlRequest"
      },
      "PdqHashResult": {
        "properties": {
          "original": {
            "type": "string",
            "title": "Original"
          },
          "rotated_90": {
            "type": "string",
            "title": "Rotated 90"
          },
          "rotated_180": {
            "type": "string",
            "title": "Rotated 180"
          },
          "rotated_270": {
            "type": "string",
            "title": "Rotated 270"
          },
          "flipped_vertical": {
            "type": "string",
            "title": "Flipped Vertical"
          },
          "flipped_horizontal": {
            "type": "string",
            "title": "Flipped Horizontal"
          },
          "rotated_90_flipped": {
            "type": "string",
            "title": "Rotated 90 Flipped"
          },
          "rotated_270_flipped": {
            "type": "string",
            "title": "Rotated 270 Flipped"
          },
          "quality": {
            "type": "number",
            "title": "Quality"
          }
        },
        "type": "object",
        "required": [
          "original",
          "rotated_90",
          "rotated_180",
          "rotated_270",
          "flipped_vertical",
          "flipped_horizontal",
          "rotated_90_flipped",
          "rotated_270_flipped",
          "quality"
        ],
        "title": "PdqHashResult"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}